# Supabase (https://supabase.com 에서 프로젝트 생성 후 Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에_anon_public_키_입력
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_키_입력  # 관리자 페이지용, 절대 공개 금지

# 관리자 페이지 비밀번호 (기본값: honsul1234)
NEXT_PUBLIC_ADMIN_PASSWORD=여기에_비밀번호_설정

# 카카오맵 (나중에 지도 연동 시)
# NEXT_PUBLIC_KAKAO_MAP_KEY=여기에_카카오맵_JavaScript_키_입력
